# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=dev
LOG_LEVEL=INFO
WORKDIR=~/.enginai/workspace

# ─── GitHub ──────────────────────────────────────────────────────────────────
GITHUB_TOKEN=your_github_personal_access_token
DEFAULT_BASE_BRANCH=main
CREATE_DRAFT_PR=false

# ─── Gemini (optional fallback) ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_DAILY_LIMIT=1450

# ─── Ollama ──────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_GPU_ENABLED=true
OLLAMA_GPU_LAYERS=-1

# Models per task type
OLLAMA_MODEL_PLANNER=deepseek-r1:7b-qwen-distill-q4_K_M
OLLAMA_MODEL_CODER=qwen2.5-coder:7b-instruct-q4_K_M
OLLAMA_MODEL_REVIEWER=qwen2.5-coder:7b-instruct-q4_K_M
OLLAMA_MODEL_SUMMARIZER=qwen2.5-coder:7b-instruct-q4_K_M

# Generation parameters
# OLLAMA_NUM_PREDICT: max tokens the model generates per request
# Recommended: 4096 (was 2048 — increase to avoid file truncation)
OLLAMA_NUM_PREDICT=4096

# OLLAMA_NUM_CTX: context window size in tokens
# 4096 fits comfortably in 4GB VRAM with q4_K_M models
# Increase to 8192 only if you have 6GB+ VRAM
OLLAMA_NUM_CTX=4096

# OLLAMA_TEMPERATURE: 0.0 = deterministic, 1.0 = creative
# Recommended: 0.2 for code generation (less hallucination)
# The planner agent always overrides this to 0.2 regardless
OLLAMA_TEMPERATURE=0.2

# OLLAMA_TOP_P: nucleus sampling
OLLAMA_TOP_P=0.9

# ─── Project defaults ────────────────────────────────────────────────────────
DEFAULT_AUTHOR=Your Name
DEFAULT_LICENSE=MIT
