# ==========================================
# AI DEV AGENT - CONFIGURAÇÃO MVP COMPLETO
# ==========================================
# Copie este arquivo para .env e preencha os valores

# === AMBIENTE ===
APP_ENV=dev
LOG_LEVEL=INFO
WORKDIR=~/.aidevagent/workspace

# === GIT & GITHUB ===
# Token: https://github.com/settings/tokens
# Permissões necessárias: repo, workflow
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_BASE_URL=https://api.github.com
DEFAULT_BASE_BRANCH=main
CREATE_DRAFT_PR=true

# === GEMINI (PRIMÁRIO - GRÁTIS) ===
# API Key: https://aistudio.google.com/apikey
# Limite grátis: 1.500 requisições/dia
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL_PLANNER=gemini-2.0-flash-exp
GEMINI_MODEL_CODER=gemini-2.0-flash-exp
GEMINI_MODEL_REVIEWER=gemini-2.0-flash-exp
GEMINI_MODEL_SUMMARIZER=gemini-2.0-flash-exp
GEMINI_DAILY_LIMIT=1450
GEMINI_RATE_LIMIT_RETRY=true
GEMINI_RATE_LIMIT_WAIT_SECONDS=60
GEMINI_TRACK_USAGE=true

# === OLLAMA (SECUNDÁRIO - LOCAL COM GPU) ===
# Download: https://ollama.com
# Modelos: ollama pull qwen2.5-coder:7b
OLLAMA_HOST=http://localhost:11434
OLLAMA_GPU_ENABLED=true
OLLAMA_GPU_LAYERS=-1
OLLAMA_MODEL_PLANNER=deepseek-r1:7b
OLLAMA_MODEL_CODER=qwen2.5-coder:7b
OLLAMA_MODEL_REVIEWER=qwen2.5-coder:7b
OLLAMA_MODEL_SUMMARIZER=qwen2.5-coder:7b
OLLAMA_NUM_PREDICT=2048
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.9

# === ROTEAMENTO LLM ===
LLM_PROVIDER_PRIMARY=gemini
LLM_PROVIDER_SECONDARY=ollama
LLM_FALLBACK_ON_RATE_LIMIT=true
LLM_AUTO_SWITCH_ENABLED=true

# === EMBEDDINGS (LOCAL - HUGGINGFACE) ===
# Modelos disponíveis:
# - all-MiniLM-L6-v2 (80MB, rápido)
# - all-mpnet-base-v2 (420MB, melhor qualidade)
# - nomic-ai/nomic-embed-text-v1.5 (550MB, SOTA)
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32
EMBEDDING_CACHE_DIR=~/.aidevagent/embeddings

# === VECTOR STORE (LOCAL - FAISS) ===
VECTOR_STORE=faiss
VECTOR_DB_PATH=~/.aidevagent/vectordb
VECTOR_INDEX_TYPE=IVFFlat
VECTOR_METRIC=cosine
MAX_FILES_INDEX=10000
MAX_CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Arquivos/pastas a ignorar
IGNORE_GLOBS=node_modules/**,dist/**,.venv/**,build/**,__pycache__/**,*.min.js,*.map,*.pyc,.git/**,*.egg-info/**,.pytest_cache/**

# === EXECUTOR (COMANDOS) ===
TEST_COMMAND_OVERRIDE=
LINT_COMMAND_OVERRIDE=
TYPECHECK_COMMAND_OVERRIDE=
MAX_EXECUTION_TIME=300
ENABLE_SANDBOX=false

# === MEMÓRIA (SQLITE) ===
MEMORY_DB_PATH=~/.aidevagent/memory.db
ENABLE_LEARNING=true
MEMORY_RETENTION_DAYS=90
STORE_ERROR_RESOLUTIONS=true

# === LOGS ===
LOG_FILE=~/.aidevagent/logs/agent.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5
LOG_JSON_FORMAT=false

# === PERFORMANCE ===
MAX_CONCURRENT_TASKS=3
ENABLE_CHECKPOINTS=true
CHECKPOINT_DIR=~/.aidevagent/checkpoints

# === TEMPLATES ===
TEMPLATES_DIR=~/.aidevagent/templates
DEFAULT_AUTHOR=Your Name
DEFAULT_EMAIL=your.email@example.com
DEFAULT_LICENSE=MIT
DEFAULT_PYTHON_VERSION=3.11
DEFAULT_NODE_VERSION=20

# === PROJETO DEFAULTS ===
DEFAULT_DATABASE=postgres
DEFAULT_INCLUDE_AUTH=true
DEFAULT_INCLUDE_DOCKER=true
DEFAULT_INCLUDE_CI=true
DEFAULT_INCLUDE_TESTS=true

# === SEGURANÇA ===
# Redação de secrets em logs
REDACT_SECRETS=true
# Confirmações obrigatórias
CONFIRM_DESTRUCTIVE_ACTIONS=true
CONFIRM_FILE_DELETION=true
CONFIRM_FORCE_PUSH=true

# === DEBUG (DESENVOLVIMENTO) ===
DEBUG_MODE=false
VERBOSE_LOGGING=false
SAVE_PROMPTS=false
SAVE_RESPONSES=false
